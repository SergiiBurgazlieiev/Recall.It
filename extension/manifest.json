{
  "name": "My Extension",
  "version": "0.0.1",
  "manifest_version": 2,
  "browser_action": {
    "default_popup": "index.html"
  },
  "permissions": ["activeTab", "storage", "contentSettings"],
  "content_scripts": [
    {
      "matches": ["https://www.amazon.com/*", "https://smile.amazon.com/*"],

      "js": ["content.js", "/utils/iframeResizer.min.js"],
      "run_at": "document_end"
    }
  ]
}
